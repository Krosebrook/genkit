set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEBUG_OUTPUT_DIR="$WORKSPACE_ROOT/debug-output"

log() {
    echo -e "${BLUE}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} $1"
}

success() {
    echo -e "${GREEN}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} ✓ $1"
}

error() {
    echo -e "${RED}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} ✗ $1"
}

warn() {
    echo -e "${YELLOW}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} ⚠ $1"
}

# Create debug output directory
setup_debug_dirs() {
    log "Setting up debug directories..."
    mkdir -p "$DEBUG_OUTPUT_DIR"/{logs,profiles,traces,dumps}
    success "Debug directories created at $DEBUG_OUTPUT_DIR"
}

# Show system information
show_system_info() {
    log "System Information:"
    echo "  OS: $(uname -s) $(uname -r)"
    echo "  Architecture: $(uname -m)"
    echo "  Node.js: $(node --version 2>/dev/null || echo 'Not found')"
    echo "  pnpm: $(pnpm --version 2>/dev/null || echo 'Not found')"
    echo "  Go: $(go version 2>/dev/null | cut -d' ' -f3 || echo 'Not found')"
    echo "  Python: $(python --version 2>/dev/null || echo 'Not found')"
    echo "  Workspace: $WORKSPACE_ROOT"
    echo "  Debug Output: $DEBUG_OUTPUT_DIR"
}

# Check running processes
check_processes() {
    log "Checking Genkit processes..."
    
    local genkit_processes=$(ps aux | grep -E "(genkit|node.*genkit)" | grep -v grep || true)
    if [ -n "$genkit_processes" ]; then
        echo "Running Genkit processes:"
        echo "$genkit_processes"
    else
        echo "No Genkit processes found"
    fi
    
    # Check for debug ports
    local debug_ports=(9229 4000 4001)
    for port in "${debug_ports[@]}"; do
        local process=$(lsof -ti:$port 2>/dev/null || true)
        if [ -n "$process" ]; then
            warn "Port $port is in use by process $process"
        else
            success "Port $port is available"
        fi
    done
}

# Clean debug artifacts
clean_debug() {
    log "Cleaning debug artifacts..."
    
    if [ -d "$DEBUG_OUTPUT_DIR" ]; then
        rm -rf "$DEBUG_OUTPUT_DIR"/*
        success "Debug output cleaned"
    fi
    
    # Clean build artifacts
    find "$WORKSPACE_ROOT" -name "lib-debug" -type d -exec rm -rf {} + 2>/dev/null || true
    find "$WORKSPACE_ROOT" -name "*.prof" -type f -delete 2>/dev/null || true
    find "$WORKSPACE_ROOT" -name ".tsbuildinfo" -type f -delete 2>/dev/null || true
    
    success "Debug artifacts cleaned"
}

# Start debug session
start_debug_session() {
    local component=${1:-"all"}
    
    log "Starting debug session for: $component"
    setup_debug_dirs
    
    # Source debug environment
    if [ -f "$WORKSPACE_ROOT/debug.env" ]; then
        source "$WORKSPACE_ROOT/debug.env"
        success "Debug environment loaded"
    fi
    
    case $component in
        "cli")
            log "Starting CLI debug session..."
            cd "$WORKSPACE_ROOT"
            pnpm debug:build:cli
            ;;
        "core")
            log "Starting core debug session..."
            cd "$WORKSPACE_ROOT"
            pnpm debug:watch:core &
            success "Core watch mode started (PID: $!)"
            ;;
        "ui")
            log "Starting UI debug session..."
            cd "$WORKSPACE_ROOT"
            pnpm debug:build:cli
            genkit start --debug --port 4001
            ;;
        "all"|*)
            log "Starting full debug session..."
            cd "$WORKSPACE_ROOT"
            pnpm debug:build:all
            ;;
    esac
}

# Monitor debug session
monitor_debug() {
    log "Monitoring debug session..."
    
    # Show real-time logs
    if [ -f "$DEBUG_OUTPUT_DIR/logs/debug.log" ]; then
        tail -f "$DEBUG_OUTPUT_DIR/logs/debug.log" &
        local tail_pid=$!
        
        trap "kill $tail_pid 2>/dev/null || true" EXIT
        
        log "Monitoring debug logs (Ctrl+C to stop)..."
        wait $tail_pid
    else
        warn "No debug logs found at $DEBUG_OUTPUT_DIR/logs/debug.log"
    fi
}

# Generate debug report
generate_report() {
    local report_file="$DEBUG_OUTPUT_DIR/debug-report-$(date +%Y%m%d-%H%M%S).md"
    
    log "Generating debug report..."
    
    cat > "$report_file" << EOF
# Genkit Debug Report

Generated: $(date)
Workspace: $WORKSPACE_ROOT

## System Information
$(show_system_info)

## Running Processes
$(check_processes)

## Build Status
EOF

    # Check build status
    if [ -d "$WORKSPACE_ROOT/js/core/lib" ]; then
        echo "- ✓ Core built" >> "$report_file"
    else
        echo "- ✗ Core not built" >> "$report_file"
    fi
    
    if [ -d "$WORKSPACE_ROOT/genkit-tools/cli/dist" ]; then
        echo "- ✓ CLI built" >> "$report_file"
    else
        echo "- ✗ CLI not built" >> "$report_file"
    fi
    
    cat >> "$report_file" << EOF

## Debug Files
$(find "$DEBUG_OUTPUT_DIR" -type f -name "*.log" -o -name "*.prof" -o -name "*.trace" 2>/dev/null | sort || echo "No debug files found")

## Recent Errors
EOF

    # Include recent errors if available
    if [ -f "$DEBUG_OUTPUT_DIR/logs/debug.log" ]; then
        echo "### Last 20 error lines:" >> "$report_file"
        grep -i "error\|exception\|failed" "$DEBUG_OUTPUT_DIR/logs/debug.log" | tail -20 >> "$report_file" 2>/dev/null || echo "No errors found" >> "$report_file"
    fi
    
    success "Debug report generated: $report_file"
}

# Show usage
show_usage() {
    cat << EOF
Genkit Debug Tools

Usage: $0 <command> [options]

Commands:
  setup           Set up debug environment and directories
  info            Show system information
  processes       Check running Genkit processes
  clean           Clean debug artifacts and outputs
  start [comp]    Start debug session (comp: cli, core, ui, all)
  monitor         Monitor debug logs in real-time
  report          Generate comprehensive debug report
  help            Show this help message

Examples:
  $0 setup                # Set up debug environment
  $0 start cli            # Start CLI debug session
  $0 start core           # Start core components in watch mode
  $0 monitor              # Monitor debug logs
  $0 report               # Generate debug report
  $0 clean                # Clean all debug artifacts

Environment Variables:
  DEBUG_OUTPUT_DIR        Debug output directory (default: ./debug-output)
EOF
}

# Main command processing
main() {
    case "${1:-help}" in
        "setup")
            setup_debug_dirs
            ;;
        "info")
            show_system_info
            ;;
        "processes")
            check_processes
            ;;
        "clean")
            clean_debug
            ;;
        "start")
            start_debug_session "${2:-all}"
            ;;
        "monitor")
            monitor_debug
            ;;
        "report")
            generate_report
            ;;
        "help"|"--help"|"-h")
            show_usage
            ;;
        *)
            error "Unknown command: $1"
            show_usage
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"